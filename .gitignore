# .gitignore — FewVision

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# ============================================================
# Virtual Environments
# ============================================================
venv/
env/
.venv/
.env

# ============================================================
# IDE / Editor
# ============================================================
.vscode/
.idea/
*.swp
*.swo

# ============================================================
# macOS
# ============================================================
.DS_Store
.AppleDouble
.LSOverride

# ============================================================
# Generated Runtime Data — NEVER commit these
# ============================================================
data/uploads/
data/augmented/
data/reports/
data/logs/
data/temp/
data/embeddings/
data/memory_bank/
data/inference/

# Keep the data/ directory structure in git
!data/.gitkeep
!data/memory_bank/.gitkeep
!data/inference/.gitkeep

# Legacy root-level data directories (from old structure)
uploads/
augmented_dataset/
reports/
logs/

# ============================================================
# Model weights & ML artefacts
# ============================================================
# Generated numpy arrays
*.npy
*.npz

# PyTorch checkpoints
*.pth
*.pt
*.ckpt

# ============================================================
# DINOv2 / torch.hub cache
# ============================================================
# These live in ~/.cache/torch/hub — no need to ignore here,
# but listed for reference. Do NOT commit model weights.

# ============================================================
# Test datasets and sample images
# ============================================================
images/

# ============================================================
# Test / Coverage
# ============================================================
htmlcov/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.pytest_cache/

# ============================================================
# Logs
# ============================================================
*.log

# ============================================================
# Jupyter
# ============================================================
.ipynb_checkpoints/
*.ipynb

# ============================================================
# Misc
# ============================================================
pipeline.png
